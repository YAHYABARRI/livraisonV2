# Copy this file to .env locally and fill real values.
# Never commit .env.

MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=quickship
MYSQL_USER=quickship
MYSQL_PASSWORD=change-me-db-password

# Use a long random hexadecimal/base64 secret.
JWT_SECRET=change-me-long-random-jwt-secret

APP_ADMIN_EMAIL=admin@example.com

# Option A: plain password kept only in local/server environment.
APP_ADMIN_PASSWORD=change-me-admin-password

# Option B: BCrypt hash instead of plain password.
# If set, APP_ADMIN_PASSWORD_HASH is used and APP_ADMIN_PASSWORD can be empty.
APP_ADMIN_PASSWORD_HASH=

APP_ADMIN_FIRST_NAME=AFRIDEEX
APP_ADMIN_LAST_NAME=Admin
APP_ADMIN_PHONE=0600000000

# Comma-separated frontend origins allowed to call the backend.
# Example: https://your-site.netlify.app,https://your-domain.com
CORS_ALLOWED_ORIGINS=https://your-site.netlify.app
